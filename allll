#include <iostream>
using namespace std;
class Shape {
public:
    virtual double getPerimeter() = 0;
};
class Rectangle : public Shape {
private:
    double length;
    double width;

public:
    Rectangle(double l, double w) {
        length = l;
        width = w;
    }
    double getPerimeter() override {
        return 2 * (length + width);
    }
};


class Trapezoid : public Shape {
private:
    double a, b, c, d;

public:
    Trapezoid(double side1, double side2, double side3, double side4) {
        a = side1;
        b = side2;
        c = side3;
        d = side4;
    }
    double getPerimeter() override {
        return a + b + c + d;
    }
};
int main() {
    Rectangle rect(5, 3);
    Trapezoid trap(4, 6, 5, 7);
    cout << "martkutxedis perimetri: " << rect.getPerimeter() << endl;
    cout << "trapeciis perimetri: " << trap.getPerimeter() << endl;
    return 0;
}
